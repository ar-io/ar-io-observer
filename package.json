    "@types/express-prometheus-middleware": "^1.2.1",
    "@types/fs-extra": "^11.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.14",
    "@types/sinon": "^17.0.4",
    "@types/source-map-support": "^0.5.4",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/yargs": "^17.0.28",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
